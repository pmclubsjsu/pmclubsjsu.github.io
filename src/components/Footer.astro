---
---

<footer class="footer" id="contact">
  <div class="footer__inner">
    <div class="footer__top">
      <img src="/images/logo.png" alt="PM Club SJSU" class="footer__logo" />
      <a href="mailto:outreach@pmclubsjsu.com" class="footer__email">
        outreach@pmclubsjsu.com
      </a>
    </div>
    <div class="footer__divider"></div>
    <p class="footer__copy">© 2026 PM Club SJSU. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    padding: 48px 24px;
    border-top: 1px solid var(--bg-card-border);
  }

  .footer__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .footer__top {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .footer__logo {
    height: 36px;
    width: auto;
    object-fit: contain;
    opacity: 0.9;
  }

  .footer__email {
    font-size: 0.9rem;
    color: var(--text-secondary);
    transition: color 0.2s;
  }

  .footer__email:hover {
    color: #4f8ef7;
  }

  .footer__divider {
    width: 100%;
    height: 1px;
    background: var(--bg-card-border);
  }

  .footer__copy {
    font-size: 0.82rem;
    color: var(--text-muted);
  }
</style>
