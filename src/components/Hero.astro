---
---

<section class="hero" id="hero">
  <div class="hero__bg-glow hero__bg-glow--left"></div>
  <div class="hero__bg-glow hero__bg-glow--right"></div>
  <div class="hero__inner">
    <div class="hero__badge">Product Management Club</div>
    <h1 class="hero__title">
      Product Management Club<br />
      <span class="hero__title-highlight">at SJSU</span>
    </h1>
    <p class="hero__subtitle">
      PM Club accelerates students' path to succeeding in the job market
      with opportunities to network, learn, and gain hands-on experience.
    </p>
    <a href="#join" class="hero__cta">Join Now</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    padding: calc(var(--nav-height) + 48px) 24px 96px;
  }

  .hero__bg-glow {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.18;
    pointer-events: none;
  }

  .hero__bg-glow--left {
    background: #4f8ef7;
    top: 10%;
    left: -10%;
  }

  .hero__bg-glow--right {
    background: #7c5cfc;
    bottom: 10%;
    right: -10%;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }

  .hero__badge {
    display: inline-block;
    padding: 6px 18px;
    border-radius: 100px;
    border: 1px solid rgba(79, 142, 247, 0.35);
    background: rgba(79, 142, 247, 0.08);
    font-size: 0.8rem;
    font-weight: 600;
    color: #4f8ef7;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .hero__title {
    font-size: clamp(2.2rem, 6vw, 4rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .hero__title-highlight {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__subtitle {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: var(--text-secondary);
    max-width: 580px;
    line-height: 1.7;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 48px;
    border-radius: 10px;
    background: var(--accent-gradient);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 32px rgba(124, 92, 252, 0.35);
  }

  .hero__cta:hover {
    opacity: 0.9;
    transform: translateY(-2px);
    box-shadow: 0 8px 40px rgba(124, 92, 252, 0.5);
  }
</style>
